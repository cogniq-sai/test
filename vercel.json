{
  "version": 2,
  "builds": [
    {
      "src": "ai-seo-frontend-latest-main/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "$1"
    }
  ]
}
